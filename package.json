{
  "name": "casecellshop",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["backend", "frontend"],
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm -w backend run dev",
    "dev:web": "npm -w frontend run dev",
    "test": "npm -w backend run test && npm -w frontend run test",
    "build": "npm -w backend run typecheck && npm -w frontend run build"
  },
  "devDependencies": { "concurrently": "^9.1.0" }
}
