# A app roda sem este arquivo — todos os valores abaixo são os defaults.
# Para ajustar, exporte as variáveis no seu shell ou crie um .env local
# que seja carregado pelo seu toolchain (ex: direnv, dotenv-cli).

# Back-end
PORT=3001
DATABASE_PATH=./data/casecellshop.sqlite

# ERP simulado
ERP_LATENCY_MS=800
ERP_TIMEOUT_MS=1500
ERP_FAILURE_RATE=0.25
ERP_MAX_RETRIES=2

# Logs (fatal|error|warn|info|debug|trace|silent)
LOG_LEVEL=info

# Front-end — Next.js usa para buscar produtos no SSR
BACKEND_URL=http://localhost:3001
