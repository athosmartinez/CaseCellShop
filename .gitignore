# ---------------------------------------------------------------------------
# CaseCellShop — .gitignore (Node + TypeScript: back-end e front-end)
# ---------------------------------------------------------------------------

# Spec-driven development — notas internas do processo (specs e planos).
# Não fazem parte da entrega: apenas README, PROMPTS.md (curado) e o código
# vão para o repositório público. Mantém o histórico do desafio limpo.
docs/superpowers/

# Dependências
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Builds / artefatos de compilação
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.vite/
*.tsbuildinfo

# Cobertura de testes e relatórios
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/

# Variáveis de ambiente (mantém apenas os exemplos versionados)
.env
.env.*
!.env.example
!.env.*.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Caches de ferramentas
.cache/
.turbo/
.eslintcache
.stylelintcache
.parcel-cache/

# Banco de dados local / dados temporários
*.sqlite
*.sqlite3
*.db
tmp/
temp/

# Sistema operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editores e IDEs
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
